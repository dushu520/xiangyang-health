{
  "caches": [
    {
      "source": "/assets/*",
      "cacheTtl": 31536000
    },
    {
      "source": "*.html",
      "cacheTtl": 600
    }
  ],
  "headers": [
    {
      "source": "/assets/*.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/*.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "*.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600"
        }
      ]
    }
  ]
}
